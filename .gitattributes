# Normalize line endings
* text=auto

# Force LF for PHP and web files
*.php text eol=lf
*.css text eol=lf
*.js  text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.md  text eol=lf
*.txt text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.svg  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.zip  binary
